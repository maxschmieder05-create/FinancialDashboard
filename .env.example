# Copy this file to `.env.local` and paste your real key there.
# Never commit `.env.local`; this repo's `.gitignore` excludes it.
#
# Keep this name WITHOUT a `NEXT_PUBLIC_` prefix. In Next.js, variables with
# `NEXT_PUBLIC_` are bundled into browser JavaScript and are not confidential.

# FactSet API-key auth uses your username-serial as the Basic Auth username.
FACTSET_USERNAME_SERIAL=your_username_serial_here

# Enterprise fundamentals, estimates, ownership, segment data, market data, and deal intelligence.
FACTSET_API_KEY=your_factset_api_key_here

# Best free primary source for live/near-live U.S. stock quotes, price targets, and recommendations.
FINNHUB_API_KEY=your_finnhub_api_key_here

# Free fallback for latest quotes and analyst target data.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
